<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:id="@+id/ivCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <androidx.cardview.widget.CardView
            android:layout_width="60dp"
            android:layout_height="60dp"
            app:cardCornerRadius="30dp"
            app:cardElevation="0dp">
            <ImageView
                android:id="@+id/ivDonorImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/person1"
                android:scaleType="centerCrop"/>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvDonorName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loading Name..."
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333333"/>

            <TextView
                android:id="@+id/tvDonorBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Newbie"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#FF9800"
                android:layout_marginTop="2dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/back"
                    android:rotation="180"
                    app:tint="#FF4C4C"/> <TextView
                android:id="@+id/tvDonorPhone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+880 1XXX..."
                android:textSize="14sp"
                android:textColor="#555555"
                android:layout_marginStart="6dp"/>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvDonorBloodGroup"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/circle_red_filled"
            android:gravity="center"
            android:text="A+"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>