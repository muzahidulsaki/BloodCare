<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="35dp"
    android:background="#FFFFFF">

    <RelativeLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/back"
            app:tint="#333" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Profile Details"
            android:textColor="#333"
            android:textSize="20sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/headerLayout"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingBottom="20dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    app:cardCornerRadius="50dp"
                    app:cardElevation="2dp">

                    <ImageView
                        android:id="@+id/ivUserProfile"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/person1" />
                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/tvUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="15dp"
                    android:text="Loading Name..."
                    android:textColor="#000"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvUserBlood"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="Loading..."
                    android:textColor="#555"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnChat"
                        android:layout_width="140dp"
                        android:layout_height="45dp"
                        android:background="@drawable/bg_button_rounded"
                        android:backgroundTint="#FF4C4C"
                        android:text="Chat Now"
                        android:textColor="#FFFFFF"
                        android:textAllCaps="false" />

                    <View android:layout_width="20dp" android:layout_height="1dp" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnCall"
                        android:layout_width="140dp"
                        android:layout_height="45dp"
                        android:background="@drawable/bg_button_rounded"
                        android:backgroundTint="#FFFFFF"
                        android:text="Call"
                        android:textColor="#FF4C4C"
                        android:stateListAnimator="@null"
                        android:elevation="0dp"
                        android:textAllCaps="false"
                        />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginTop="10dp">

                <LinearLayout
                    android:id="@+id/tabAbout"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/txtAbout"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="About"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#000"
                        android:padding="10dp"/>
                    <View
                        android:id="@+id/lineAbout"
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:background="#FF4C4C"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/tabPosts"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/txtPosts"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Create Ads"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#999"
                        android:padding="10dp"/>
                    <View
                        android:id="@+id/linePosts"
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:background="#E0E0E0"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutAboutContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="12dp">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/location" app:tint="#FF8A80"/>
                    <TextView android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:text="City"
                        android:layout_marginStart="15dp" android:textColor="#777"/>
                    <TextView android:id="@+id/tvCity" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="Dhaka"
                        android:textColor="#333" android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="12dp">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/hospital2" app:tint="#FF8A80"/>
                    <TextView android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:text="Country"
                        android:layout_marginStart="15dp" android:textColor="#777"/>
                    <TextView android:id="@+id/tvCountry" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="Bangladesh"
                        android:textColor="#333" android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="12dp">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/time" app:tint="#FF8A80"/> <TextView android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content" android:text="Age"
                    android:layout_marginStart="15dp" android:textColor="#777"/>
                    <TextView android:id="@+id/tvAge" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="Loading..."
                        android:textColor="#333" android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="12dp">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/person1" app:tint="#FF8A80"/>
                    <TextView android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:text="Gender"
                        android:layout_marginStart="15dp" android:textColor="#777"/>
                    <TextView android:id="@+id/tvGender" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="Loading..."
                        android:textColor="#333" android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="12dp">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/ic_calendar" app:tint="#FF8A80"/>
                    <TextView android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:text="Date of Birth"
                        android:layout_marginStart="15dp" android:textColor="#777"/>
                    <TextView android:id="@+id/tvDOB" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="Loading..."
                        android:textColor="#333" android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="12dp">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/back" android:rotation="180" app:tint="#FF8A80"/>
                    <TextView android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:text="Mobile"
                        android:layout_marginStart="15dp" android:textColor="#777"/>
                    <TextView android:id="@+id/tvMobile" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="017XXXXXXXX"
                        android:textColor="#333" android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="12dp">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/ic_close" app:tint="#FF8A80"/>
                    <TextView android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:text="Email"
                        android:layout_marginStart="15dp" android:textColor="#777"/>
                    <TextView android:id="@+id/tvEmail" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="email@example.com"
                        android:textColor="#333" android:textStyle="bold"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="About User"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginTop="20dp"
                    android:textColor="#000"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="A dedicated blood donor willing to help anyone in need. Contact me for emergency."
                    android:textColor="#777"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutPostsContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:padding="10dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvUserPosts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"/>

                <TextView
                    android:id="@+id/tvNoPosts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No posts available"
                    android:gravity="center"
                    android:padding="20dp"
                    android:visibility="gone"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</RelativeLayout>